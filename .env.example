# Shopify credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products

# App configuration, TOML Writer (used by bun run update:config)
APP_NAME="My Shopify App"
APP_HANDLE="my-shopify-app"
HOST="https://your-tunnel-url.trycloudflare.com"
POS_EMBEDDED=false
DIRECT_API_MODE="offline"
EMBEDDED_APP_DIRECT_API_ACCESS=true
AUTO_UPDATE_URL=true

# Connection pool size (default: 5)
DB_POOL_SIZE=5

# Dev store fallback (optional)
DEV_STORE_URL=
