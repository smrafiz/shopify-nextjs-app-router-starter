SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products
HOST=https://your-tunnel-url.trycloudflare.com
DATABASE_URL=postgresql://user:password@localhost:5432/shopify_starter
DIRECT_DATABASE_URL=${DATABASE_URL}

# Token encryption key — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Cron job auth — run: node -e "console.log(crypto.randomUUID())"
CRON_SECRET=

# TOML Writer (used by pnpm run update:config)
APP_NAME=My Shopify App
APP_HANDLE=my-shopify-app
SHOPIFY_APP_URL=https://example.com
DEV_STORE_URL=your-store.myshopify.com
AUTO_UPDATE_URL=true
DIRECT_API_MODE=offline
EMBEDDED_APP_DIRECT_API_ACCESS=true
POS_EMBEDDED=false
