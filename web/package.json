    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.0",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
