{
    "name": "shopify-starter-web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "prebuild": "pnpm graphql-codegen",
        "build": "next build",
        "dev": "next dev",
        "migrate": "prisma migrate dev",
        "postinstall": "prisma generate",
        "prisma:push": "pnpx prisma db push",
        "prisma:pull": "pnpx prisma db pull",
        "prisma:studio": "pnpx prisma studio",
        "prisma:migrate": "pnpx prisma migrate dev --name",
        "graphql-codegen": "graphql-codegen --config codegen.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "@graphql-typed-document-node/core": "^3.2.0",
        "@hookform/resolvers": "^5.2.2",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@shopify/app-bridge-react": "^4.2.10",
        "@shopify/app-bridge-types": "^0.7.0",
        "@shopify/polaris-types": "^1.0.7",
        "@shopify/shopify-api": "^13.0.0",
        "@tanstack/react-query": "^5.100.9",
        "@tanstack/react-query-devtools": "^5.100.9",
        "dotenv": "^17.4.2",
        "graphql": "^16.14.0",
        "graphql-request": "^7.4.0",
        "validator": "^13.15.35",
        "isomorphic-dompurify": "^3.12.0",
        "next": "16.2.5",
        "pg": "^8.20.0",
        "prisma": "^7.8.0",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "react-hook-form": "^7.75.0",
        "zod": "^4.4.3",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@graphql-codegen/cli": "^7.0.0",
        "@graphql-codegen/client-preset": "^6.0.0",
        "@shopify/api-codegen-preset": "^2.0.0",
        "@types/validator": "^13.15.10",
        "eslint": "^10.3.0",
        "eslint-config-next": "16.2.5",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "@tailwindcss/postcss": "^4.2.4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.6.1",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "autoprefixer": "^10.5.0",
        "jest": "^30.3.0",
        "jest-mock-extended": "^4.0.1",
        "postcss": "^8.5.14",
        "tailwindcss": "^4.2.4",
        "ts-jest": "^29.4.9",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    },
    "pnpm": {
        "overrides": {
            "@types/react": "19.2.14",
            "@types/react-dom": "19.2.3"
        }
    }
